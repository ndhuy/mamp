# Copy this file to `.env` on the server and fill in real secrets.
#   cp .env.prod.example .env  &&  nano .env
# Never commit the real .env.

# --- Database ---
POSTGRES_DB=msamp
POSTGRES_USER=msamp
# Use a long random value:  openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_db_password

# --- Object storage (MinIO) ---
MINIO_ROOT_USER=msampminio
# openssl rand -base64 24
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password

# --- Backend security ---
# JWT signing key — must be >= 32 bytes.  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_bytes_long

# --- Initial administrator (created on first run only) ---
# No defaults are baked in — you MUST set the username and email here.
INITIAL_ADMIN_USERNAME=CHANGE_ME_admin_username
INITIAL_ADMIN_EMAIL=CHANGE_ME_admin@yourdomain.com
# If left blank, a random password is generated and printed once in the backend logs.
INITIAL_ADMIN_PASSWORD=CHANGE_ME_admin_password

# --- CORS ---
# The public URL(s) the browser loads the app from. When served behind a domain
# (e.g. via Cloudflare), set this to that https URL or the backend returns 403 on
# API calls. Comma-separate multiple origins. Example:
#   CORS_ORIGINS=https://test.pixorastudio.cloud
CORS_ORIGINS=https://CHANGE_ME_your_domain
